code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded;

uniform vec4 StreaksColor : source_color;
uniform sampler2D curve_frg_7 : repeat_disable;
uniform sampler2D tex_frg_2 : source_color;
uniform sampler2D tex_frg_10 : source_color;



void fragment() {
// ColorParameter:9
	vec4 n_out9p0 = StreaksColor;


// Input:3
	vec2 n_out3p0 = UV;


// Input:6
	vec4 n_out6p0 = COLOR;
	float n_out6p1 = n_out6p0.r;
	float n_out6p4 = n_out6p0.a;


// CurveTexture:7
	float n_out7p0 = texture(curve_frg_7, vec2(n_out6p1)).r;


// VectorCompose:8
	float n_in8p1 = 0.00000;
	vec2 n_out8p0 = vec2(n_out7p0, n_in8p1);


// MultiplyAdd:4
	vec2 n_in4p1 = vec2(0.25000, 1.00000);
	vec2 n_out4p0 = fma(n_out3p0, n_in4p1, n_out8p0);


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, n_out4p0);
	float n_out2p1 = n_out2p0.r;


// Texture2D:10
	vec4 n_out10p0 = texture(tex_frg_10, UV);


// SmoothStep:11
	float n_in11p1 = 1.00000;
	float n_out11p0 = smoothstep(n_out6p4, n_in11p1, n_out10p0.x);


// FloatOp:12
	float n_out12p0 = n_out2p1 * n_out11p0;


// Output:0
	ALBEDO = vec3(n_out9p0.xyz);
	ALPHA = n_out12p0;


}
"
